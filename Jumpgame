<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Game Lompat Mobile</title>
    <style>
        body { 
            margin: 0; padding: 0; overflow: hidden; 
            background: #87CEEB; font-family: sans-serif; 
            display: flex; flex-direction: column; align-items: center;
        }
        canvas { 
            display: block; background: #87CEEB; 
            border-bottom: 5px solid #555;
            width: 100%; max-width: 600px; height: auto;
        }
        .info { position: absolute; top: 10px; left: 10px; font-weight: bold; color: #fff; text-shadow: 1px 1px 2px #000; }
        .btn-jump {
            margin-top: 20px; padding: 20px 60px; 
            font-size: 24px; font-weight: bold;
            background: #ff4757; color: white; border: none;
            border-radius: 50px; box-shadow: 0 5px #c0392b;
            touch-action: manipulation;
        }
        .btn-jump:active { transform: translateY(4px); box-shadow: 0 2px #c0392b; }
    </style>
</head>
<body>

    <div class="info" id="scoreBoard">Skor: 0</div>
    <canvas id="gameCanvas" width="600" height="250"></canvas>
    
    <!-- Tombol Khusus Mobile -->
    <button class="btn-jump" id="jumpBtn">LOMPAT!</button>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const scoreBoard = document.getElementById("scoreBoard");
        const jumpBtn = document.getElementById("jumpBtn");

        let player = { x: 50, y: 200, w: 40, h: 40, dy: 0, jumpForce: 15, gravity: 0.8, grounded: false };
        let obstacles = [];
        let score = 0;
        let gameActive = true;

        function jump() {
            if (player.grounded && gameActive) {
                player.dy = -player.jumpForce;
                player.grounded = false;
            } else if (!gameActive) {
                resetGame();
            }
        }

        // Event Listener untuk HP dan PC
        jumpBtn.addEventListener("touchstart", (e) => { e.preventDefault(); jump(); });
        jumpBtn.addEventListener("mousedown", jump);
        window.addEventListener("keydown", (e) => { if (e.code === "Space") jump(); });

        function resetGame() {
            player.y = 200; player.dy = 0; obstacles = [];
            score = 0; gameActive = true; update();
        }

        function update() {
            if (!gameActive) return;

            player.dy += player.gravity;
            player.y += player.dy;

            if (player.y + player.h > canvas.height) {
                player.y = canvas.height - player.h;
                player.dy = 0;
                player.grounded = true;
            }

            if (Math.random() < 0.015) {
                obstacles.push({ x: canvas.width, y: canvas.height - 40, w: 25, h: 40 });
            }

            obstacles.forEach((obs, index) => {
                obs.x -= 6; 
                if (player.x < obs.x + obs.w && player.x + player.w > obs.x &&
                    player.y < obs.y + obs.h && player.y + player.h > obs.y) {
                    gameActive = false;
                    alert("Yah, Nabrak! Skor Kamu: " + score);
                }
                if (obs.x + obs.w < 0) {
                    obstacles.splice(index, 1);
                    score++;
                    scoreBoard.innerText = "Skor: " + score;
                }
            });

            draw();
            requestAnimationFrame(update);
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Gambar Tanah
            ctx.fillStyle = "#8B4513";
            ctx.fillRect(0, canvas.height - 5, canvas.width, 5);

            // Karakter (Bisa diganti gambar nantinya)
            ctx.fillStyle = "#e74c3c";
            ctx.fillRect(player.x, player.y, player.w, player.h);

            // Musuh
            ctx.fillStyle = "#2ecc71";
            obstacles.forEach(obs => ctx.fillRect(obs.x, obs.y, obs.w, obs.h));
        }

        update();
    </script>
</body>
</html>
